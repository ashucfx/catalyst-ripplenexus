# ─── RESEND ───────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# The "From" email address — must be from a domain verified in Resend.
# During development you can use: onboarding@resend.dev
# (but it only sends to the email you signed up with)
RESEND_FROM_EMAIL=catalyst@yourdomain.com
RESEND_FROM_NAME=Catalyst

# Where admin notifications go (your inbox)
RESEND_ADMIN_EMAIL=ashutosh6471@gmail.com

# ─── CONVERTKIT ───────────────────────────────────────────────────────
# Get your API key from: https://app.kit.com/account_settings/developer_settings
CONVERTKIT_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Newsletter form ID — get from the URL when viewing your form in ConvertKit
# e.g. https://app.kit.com/forms/1234567/edit → ID is 1234567
CONVERTKIT_NEWSLETTER_FORM_ID=1234567

# TPI leads form ID — create a second form called "TPI Leads"
CONVERTKIT_TPI_FORM_ID=7654321
