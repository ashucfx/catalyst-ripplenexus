# ─── RESEND ───────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=catalyst@yourdomain.com
RESEND_FROM_NAME=Catalyst
RESEND_ADMIN_EMAIL=you@youremail.com

# ─── CONVERTKIT (Kit) ─────────────────────────────────────────────────
# https://app.kit.com/account_settings/developer_settings
CONVERTKIT_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CONVERTKIT_NEWSLETTER_FORM_ID=1234567
CONVERTKIT_TPI_FORM_ID=7654321

# ─── SUPABASE ─────────────────────────────────────────────────────────
# https://supabase.com/dashboard → project → Settings → API
# Run supabase/schema.sql in the Supabase SQL editor first
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── UPSTASH REDIS ────────────────────────────────────────────────────
# https://console.upstash.com → create Redis database → REST API
# Falls back to in-memory if not set (fine for local dev)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── RAZORPAY (India payments) ────────────────────────────────────────
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX

# ─── PAYPAL (International payments) ──────────────────────────────────
# https://developer.paypal.com/dashboard/applications
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYPAL_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_PAYPAL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── SITE ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://www.catalystripple.com

# ─── CALENDLY (optional — shows "Book directly" in request success) ───
# Your Calendly scheduling link — e.g. https://calendly.com/yourname/audit
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/yourname/audit

# ─── PLAUSIBLE ANALYTICS (optional) ──────────────────────────────────
# https://plausible.io — privacy-friendly, no cookies, GDPR compliant
# Set to your domain: e.g. catalystripple.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=catalystripple.com

# ─── SCHEDULING SYSTEM ────────────────────────────────────────────────────────
# A strong random string — this is your admin password for /admin
ADMIN_SECRET=change-me-to-a-long-random-string

# IANA timezone for the host (slot generation, email timestamps)
# Default: Asia/Kolkata
ADMIN_TIMEZONE=Asia/Kolkata

# Vercel Cron auth secret — sent as Bearer token to /api/cron/reminders
CRON_SECRET=another-long-random-string
